msgid "minimum length (6 characters or more),"
msgstr "குறைந்தபட்ச நீளம் (6 எழுத்துகள் அல்லது அதற்கு மேல்),"

#: ../usermanual/preferences.rst:207 79fe63911b564890802adcf767131707
